FROM ${IMAGE_NAME}

RUN find /etc /root /home -type f \( -name ".profile" -o -name ".bashrc" -o -name "bash.bashrc" -o -name "profile" \) -exec sed -i '/^\s*mesg\s\+n/d' {} + || true

ENV MAMBA_ROOT_PREFIX=/openhands/micromamba \
    PATH=/openhands/micromamba/bin:$PATH \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    POETRY_VIRTUALENVS_PATH=/openhands/poetry

RUN apt-get update && \
    apt-get install -y curl bzip2 wget git build-essential ca-certificates && \
    mkdir -p ${MAMBA_ROOT_PREFIX}/bin && \
    /bin/bash -c "PREFIX_LOCATION=${MAMBA_ROOT_PREFIX} BIN_FOLDER=${MAMBA_ROOT_PREFIX}/bin INIT_YES=no CONDA_FORGE_YES=yes $(curl -L https://micro.mamba.pm/install.sh)" && \
    chmod +x ${MAMBA_ROOT_PREFIX}/bin/micromamba

RUN ${MAMBA_ROOT_PREFIX}/bin/micromamba create -y -n openhands -c conda-forge python=3.12 && \
    ${MAMBA_ROOT_PREFIX}/bin/micromamba install -n openhands -c conda-forge poetry numpy pandas requests tqdm && \
    ${MAMBA_ROOT_PREFIX}/bin/micromamba clean --all --yes

RUN mkdir -p /openhands/code

COPY OpenHands /openhands/code

WORKDIR /openhands/code

RUN apt-get update && apt-get install -y \
    build-essential \
    gfortran \
    libopenblas-dev \
    liblapack-dev \
    python3-dev \
    tmux \
    && rm -rf /var/lib/apt/lists/*

RUN ${MAMBA_ROOT_PREFIX}/bin/micromamba run -n openhands poetry config virtualenvs.in-project true && \
    ${MAMBA_ROOT_PREFIX}/bin/micromamba run -n openhands poetry install --only main --no-interaction --no-root && \
    ${MAMBA_ROOT_PREFIX}/bin/micromamba run -n openhands poetry install --only runtime --no-interaction --no-root

ENTRYPOINT ["/openhands/micromamba/bin/micromamba", "run", "-n", "openhands"]

CMD ["python"]
    